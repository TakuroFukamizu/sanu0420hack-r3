# ------------------------------------------------------------
# Pair Arcade — 環境変数テンプレート
# `.env` にコピーして値を埋める。`.env` は .gitignore で除外済み。
# すべて @app/server (Fastify) が読む。@app/web は Vite の proxy
# 経由でサーバに繋ぐので、クライアント側から参照する env は無い。
# ------------------------------------------------------------

# [Phase 1] サーバ待受ポート。未指定なら 3000。
# Vite dev server (:5173) の proxy 先と揃える必要がある。
PORT=3000

# [Phase 2] ガイド画面に表示するプレイヤー画面のフルURL。
# LGディスプレイを LAN 上から開く想定で、ノートPC の LAN IP を入れる。
# 未指定時は window.location.origin を元に推測する。
PLAYER_URL_A=http://192.168.0.10:5173/player?id=A
PLAYER_URL_B=http://192.168.0.10:5173/player?id=B

# [Phase 5] Gemini API キー。ゲーム選択 / ラウンド評価 / 最終診断に使用。
# サーバ側のみで参照し、クライアントには一切渡さない。
# 未指定ならサーバは MockAiGateway にフォールバックして固定ローテの mock 応答で動く。
GEMINI_API_KEY=

# [Phase 5] 利用する Gemini モデル。未指定なら gemini-2.5-flash。
GEMINI_MODEL=gemini-2.5-flash

# [Phase 5] Round 終了時の qualitative を Gemini でリファインするか。
# true にすると roundResult 遷移が AI 応答待ちで数百 ms 遅れる可能性あり。デフォ false。
AI_REFINE_QUALITATIVE=false

# [Phase 6] easymidi が出力する MIDI ポート名。
# 未指定 / 存在しないポート名 / easymidi ロード失敗 のいずれでも silent に no-op
# (NullMidiOutput) にフォールバックし、UX は崩れない (ハッカソン会場 MIDI 音源不在時の保険)。
# 利用可能なポート名は `node -e "console.log(require('easymidi').getOutputs())"` で確認できる。
# 例: macOS IAC Driver なら "IAC Driver Bus 1"。
MIDI_PORT=

# [Phase 3] Orchestrator の各 state 滞在時間 (ms)。
# 未指定なら shared/src/round-durations.ts の default (3000/5000/8000) が使われる。
ORCHESTRATOR_ROUND_LOADING_MS=3000
ORCHESTRATOR_ROUND_PLAYING_MS=5000
ORCHESTRATOR_ROUND_RESULT_MS=8000

